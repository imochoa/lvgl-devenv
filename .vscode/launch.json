{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug in Chrome",
            "type": "chrome",
            "request": "launch",
            "url": "http://127.0.0.1:35729/${input:app}.html",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Debug in Firefox",
            "type": "firefox",
            "request": "launch",
            "url": "http://127.0.0.1:35729/${input:app}.html",
            "webRoot": "${workspaceFolder}"
        }
    ],
    "inputs": [
        {
            "id": "app",
            "type": "pickString",
            "description": "Select app",
            "default": "hello_world",
            "options": [
                "hello_world",
                "counter",
                "shapes"
            ]
        }
    ]
}