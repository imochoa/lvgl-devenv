{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "emcmake configure",
            "type": "shell",
            "command": "emcmake cmake -S ${workspaceFolder} -B build -DCMAKE_BUILD_TYPE=Debug",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build All",
            "type": "shell",
            "command": "just build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build App",
            "type": "shell",
            "command": "just build ${input:app}",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Serve App",
            "type": "shell",
            "command": "just server ${input:app}",
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Dev Shell",
            "type": "shell",
            "command": "just dev",
            "problemMatcher": []
        },
        {
            "type": "cmake",
            "label": "CMake: configure",
            "command": "configure",
            "preset": "default",
            "problemMatcher": [],
            "detail": "CMake template configure task"
        }
    ],
    "inputs": [
        {
            "id": "app",
            "type": "pickString",
            "description": "Select app",
            "default": "hello_world",
            "options": [
                "hello_world",
                "counter",
                "shapes"
            ]
        }
    ]
}